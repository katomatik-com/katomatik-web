---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import BaseLayout from './BaseLayout.astro';

type Props = CollectionEntry<'blog'>['data'];

const {
	title,
	subtitle,
	author,
	tags,
	description,
	pubDate,
	updatedDate,
	heroImage,
} = Astro.props;
---

<BaseLayout title={title} description={description} image={heroImage}>
	<article>
		{
			heroImage && (
				<Image
					class="frame mx-auto mb-10 block w-full"
					width={1020}
					height={510}
					src={heroImage}
					alt=""
				/>
			)
		}
		<div class="mb-10 text-center">
			<div class="text-ink-muted mb-2">
				<FormattedDate date={pubDate} />
				{
					updatedDate && (
						<div class="italic">
							Last updated on <FormattedDate date={updatedDate} />
						</div>
					)
				}
			</div>
			<h1 class="text-4xl font-bold">{title}</h1>
			{subtitle && <h2 class="text-base">{subtitle}</h2>}
			{
				author && (
					<h3 class="text-ink-muted mr-px -mb-5 pr-1 text-right text-sm">
						{author}
					</h3>
				)
			}
			{
				tags && tags.length > 0 && !author && (
					<ul class="text-ink-muted -mb-6 h-6 list-none overflow-hidden text-right text-sm">
						{tags.map((tag) => (
							<li class="border-edge mt-px ml-2 inline-block w-fit border border-b-0 px-1 pt-0.5">
								{tag}
							</li>
						))}
					</ul>
				)
			}
			<hr class="border-edge mt-6" />
			{
				tags && tags.length > 0 && author && (
					<ul class="text-ink-muted -mb-6 h-6 list-none overflow-hidden text-right text-sm">
						{tags.map((tag) => (
							<li class="border-edge mb-px ml-2 inline-block w-fit border border-t-0 px-1 pt-0.5">
								{tag}
							</li>
						))}
					</ul>
				)
			}
		</div>
		<div class="prose max-w-none">
			<slot />
		</div>
	</article>
</BaseLayout>
