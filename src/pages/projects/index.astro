---
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';

const projects = (
	await getCollection('projects', ({ data }) =>
		import.meta.env.PROD ? !data.draft : true,
	)
).sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());
---

<BaseLayout
	title={`Projects · ${SITE_TITLE}`}
	description="Things we're building."
	width="wide"
>
	<h1 class="text-4xl font-bold">Projects</h1>
	<div class="wavy my-6 max-w-xs"></div>

	{projects.length === 0 && <p class="text-ink-muted">Nothing here yet.</p>}

	<ul class="mt-8 grid list-none grid-cols-1 gap-8 p-0 sm:grid-cols-2">
		{
			projects.map((project) => (
				<li class="border-edge border p-5">
					<a href={`/projects/${project.id}/`} class="group block no-underline">
						<h2 class="text-ink group-hover:text-accent text-2xl font-bold transition-colors">
							{project.data.title}
						</h2>
						<p class="text-ink-muted mt-2 text-base">
							{project.data.description}
						</p>
						<div class="text-ink-muted mt-4 flex flex-wrap items-center gap-x-3 gap-y-2 text-sm">
							<span class="border-edge border px-2 py-0.5 uppercase">
								{project.data.status}
							</span>
							<FormattedDate date={project.data.startDate} />
							{project.data.draft && (
								<span class="border-accent text-accent border px-2 py-0.5 uppercase">
									draft
								</span>
							)}
						</div>
					</a>
				</li>
			))
		}
	</ul>
</BaseLayout>
