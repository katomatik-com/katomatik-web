---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const tags: Record<string, boolean> = {};
posts.forEach((post) => {
	post.data.tags?.forEach((tag) => {
		tags[tag] = false;
	});
});
---

<BaseLayout
	title={`Blog · ${SITE_TITLE}`}
	description={SITE_DESCRIPTION}
	width="wide"
>
	{
		Object.keys(tags).length > 0 && (
			<div
				id="tag-filters"
				class="text-ink-muted -mt-11 mb-3 list-none text-right text-sm"
			>
				Tags:{' '}
				{Object.keys(tags).map((label) => (
					<button
						id={label}
						class="border-edge bg-page text-ink-muted m-1 inline-block w-fit cursor-pointer border px-1 pt-0.5"
					>
						{label}
					</button>
				))}
			</div>
		)
	}
	<ul class="grid list-none grid-cols-1 gap-8 p-0 sm:grid-cols-2">
		{
			posts.map((post, i) => (
				<li
					class:list={[i === 0 && 'text-center sm:col-span-2']}
					data-tags={JSON.stringify(post.data.tags)}
				>
					<a href={`/blog/${post.id}/`} class="group block no-underline">
						{post.data.heroImage && (
							<Image
								class="frame mb-3 w-full"
								width={720}
								height={360}
								src={post.data.heroImage}
								alt=""
							/>
						)}
						{post.data.tags &&
							post.data.tags.length > 0 &&
							post.data.heroImage && (
								<ul class="mx-2 -mt-12 mb-6 h-6 list-none overflow-hidden text-right text-sm">
									{post.data.tags?.map((tag) => (
										<li class="border-edge text-ink theme-light:bg-white/40 mx-1 inline-block w-fit border bg-white/10 px-1 pt-0.5">
											{tag}
										</li>
									))}
								</ul>
							)}
						<h4
							class:list={[
								'text-ink group-hover:text-accent font-bold transition-colors',
								i === 0 ? 'text-3xl' : 'text-xl',
							]}
						>
							{post.data.title}
						</h4>
						<p class="text-ink-muted group-hover:text-accent transition-colors">
							<FormattedDate date={post.data.pubDate} />
						</p>
					</a>
				</li>
			))
		}
	</ul>
</BaseLayout>

<script>
	const activeTags = new Set();

	function filterPosts() {
		document.querySelectorAll('li').forEach((item) => {
			const postTags = JSON.parse(item.getAttribute('data-tags') ?? '[]');
			const visible =
				activeTags.size === 0 ||
				postTags.some((t: string) => activeTags.has(t));
			item.classList.toggle('hidden', !visible);
		});
	}

	document.querySelectorAll('#tag-filters button').forEach((btn) => {
		const update = () => {
			const active = activeTags.has(btn.id);
			btn.classList.toggle('bg-ink-muted', active);
			btn.classList.toggle('text-page', active);
			btn.classList.toggle('bg-page', !active);
			btn.classList.toggle('text-ink-muted', !active);
		};
		btn.addEventListener('click', () => {
			const tag = btn.id;
			activeTags.has(tag) ? activeTags.delete(tag) : activeTags.add(tag);
			update();
			filterPosts();
		});
	});
</script>
