---
// Theme is resolved before paint by the inline script in BaseHead.astro.
// This only handles the click, so it can be a normal deferred script.
---

<button
	type="button"
	id="theme-toggle"
	class="hover-up text-ink ml-1 inline-flex items-center px-2 py-4 cursor-pointer"
>
	<span class="sr-only">Switch colour theme</span>
	{/* Sun: shown in dark theme, i.e. "switch to light" */}
	<svg
		class="theme-dark:block hidden"
		viewBox="0 0 24 24"
		width="22"
		height="22"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		aria-hidden="true"
	>
		<circle cx="12" cy="12" r="4"></circle>
		<path
			d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
		></path>
	</svg>
	{/* Moon: shown in light theme, i.e. "switch to dark" */}
	<svg
		class="theme-light:block hidden"
		viewBox="0 0 24 24"
		width="22"
		height="22"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		aria-hidden="true"
	>
		<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
	</svg>
</button>

<script>
	const root = document.documentElement;
	const button = document.getElementById('theme-toggle');

	const label = () =>
		root.getAttribute('data-theme') === 'dark'
			? 'Switch to light theme'
			: 'Switch to dark theme';

	button?.setAttribute('aria-label', label());

	button?.addEventListener('click', () => {
		const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
		root.setAttribute('data-theme', next);
		try {
			localStorage.setItem('theme', next);
		} catch {
			/* storage blocked — the choice just won't persist */
		}
		button.setAttribute('aria-label', label());
	});
</script>
