{
	"name": "katomatik-web",

	// Node 24 (LTS). Keep in step with .nvmrc and the Dockerfile's build stage —
	// three places declare Node, and they must not drift.
	"image": "mcr.microsoft.com/devcontainers/typescript-node:24",

	"postCreateCommand": "npm install",

	"forwardPorts": [4321],
	"portsAttributes": {
		"4321": {
			"label": "Astro dev server",
			"onAutoForward": "notify"
		}
	},

	"customizations": {
		"vscode": {
			"extensions": [
				"astro-build.astro-vscode",
				"unifiedjs.vscode-mdx",
				"bradlc.vscode-tailwindcss",
				"esbenp.prettier-vscode"
			],
			"settings": {
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "esbenp.prettier-vscode",
				// .astro files are formatted by the Astro extension, which loads
				// prettier-plugin-astro itself. Pointing them at Prettier directly
				// works inconsistently.
				"[astro]": {
					"editor.defaultFormatter": "astro-build.astro-vscode"
				}
			}
		}
	}
}
