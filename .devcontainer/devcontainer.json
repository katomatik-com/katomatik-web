{
	"name": "katomatik-web",

	// Node 24 (LTS). Keep in step with .nvmrc and the Dockerfile's build stage —
	// three places declare Node, and they must not drift.
	"image": "mcr.microsoft.com/devcontainers/typescript-node:24",

	"postCreateCommand": "npm install",

	// node_modules holds platform-specific native binaries (rolldown, sharp).
	// The workspace is bind-mounted from the host, so a host `npm install` (macOS)
	// would otherwise expose darwin binaries to this Linux container and break
	// `astro dev` with "Cannot find native binding". Keep node_modules as a
	// container-only volume so postCreateCommand's install populates it with Linux
	// binaries, isolated from whatever the host has.
	"mounts": [
		"source=katomatik-node-modules,target=${containerWorkspaceFolder}/node_modules,type=volume"
	],

	"forwardPorts": [4321],
	"portsAttributes": {
		"4321": {
			"label": "Astro dev server",
			"onAutoForward": "notify"
		}
	},

	"customizations": {
		"vscode": {
			"extensions": [
				"astro-build.astro-vscode",
				"unifiedjs.vscode-mdx",
				"bradlc.vscode-tailwindcss",
				"esbenp.prettier-vscode"
			],
			"settings": {
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "esbenp.prettier-vscode",
				// .astro files are formatted by the Astro extension, which loads
				// prettier-plugin-astro itself. Pointing them at Prettier directly
				// works inconsistently.
				"[astro]": {
					"editor.defaultFormatter": "astro-build.astro-vscode"
				}
			}
		}
	}
}
